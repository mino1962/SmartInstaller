<!DOCTYPE html>
<html lang="it">
<head>
<HTA:APPLICATION
  ID="SmartInstaller"
  APPLICATIONNAME="SmartInstaller"
  SCROLL="yes"
  SINGLEINSTANCE="yes"
  WINDOWSTATE="maximize"
  BORDER="thin"
  CAPTION="yes"
  MAXIMIZEBUTTON="yes"
  MINIMIZEBUTTON="yes"
/>
<meta charset="UTF-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<title>SmartInstaller - Gestore Installazioni Massive</title>
<style>
* { box-sizing: border-box; }
html, body {
  height: 100%;
  margin: 0;
  padding: 0;
}
body {
  font-family: "Segoe UI", Arial, sans-serif;
  background: #eef2ff;
  color: #1e293b;
  margin: 0;
  padding: 0;
  padding-top: 110px; /* Spazio per hdr e nav fissi */
  overflow-y: scroll; /* Forza barra verticale di sistema */
}
.hdr {
  background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
  color: white;
  padding: 10px 18px;
  display: -ms-flexbox;
  display: flex;
  -ms-flex-align: center;
  align-items: center;
  -ms-flex-pack: justify;
  justify-content: space-between;
  box-shadow: 0 2px 8px rgba(0,0,0,0.25);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 64px;
  z-index: 1000;
  overflow: hidden;
}
.hdr-logo { font-size: 21px; font-weight: 800; letter-spacing: 0.5px; }
.hdr-sub { font-size: 11px; opacity: 0.75; margin-top: 2px; }
.hdr-path { font-size: 11px; opacity: 0.65; font-family: Consolas, monospace; max-width: 420px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.nav {
  background: #1e3a8a;
  display: -ms-flexbox;
  display: flex;
  border-bottom: 3px solid #1d4ed8;
  position: fixed;
  top: 64px;
  left: 0;
  right: 0;
  height: 42px;
  z-index: 1000;
  overflow: hidden;
}
.nav-btn {
  color: rgba(255,255,255,0.65);
  border: none;
  background: none;
  padding: 9px 20px;
  cursor: pointer;
  font-size: 13px;
  font-family: "Segoe UI", Arial, sans-serif;
  font-weight: 600;
  border-bottom: 3px solid transparent;
  margin-bottom: -3px;
}
.nav-btn:hover { color: white; background: rgba(255,255,255,0.08); }
.nav-btn.active { color: white; border-bottom-color: #60a5fa; background: rgba(255,255,255,0.12); }
.main { display: block; }
.content { padding: 18px; padding-bottom: 60px; overflow: visible; }
.view { display: none; }
.view.active { display: block; }
.card {
  background: white;
  border-radius: 10px;
  box-shadow: 0 1px 6px rgba(0,0,0,0.09);
  padding: 18px;
  margin-bottom: 14px;
}
.card-title {
  font-size: 15px;
  font-weight: 700;
  color: #1e3a8a;
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 2px solid #e2e8f0;
}
.pcard-grid {
  display: -ms-flexbox;
  display: flex;
  -ms-flex-wrap: wrap;
  flex-wrap: wrap;
  gap: 14px;
  margin-top: 12px;
}
.pcard {
  background: white;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.09);
  padding: 20px;
  width: 260px;
  cursor: pointer;
  border: 2px solid transparent;
  -webkit-transition: all 0.18s;
  transition: all 0.18s;
}
.pcard:hover { border-color: #3b82f6; box-shadow: 0 4px 14px rgba(59,130,246,0.18); }
.pcard.sel { border-color: #1d4ed8; box-shadow: 0 4px 18px rgba(29,78,216,0.25); background: #eff6ff; }
.pcard-icon { font-size: 32px; margin-bottom: 10px; }
.pcard-name { font-size: 16px; font-weight: 700; color: #1e3a8a; margin-bottom: 5px; }
.pcard-desc { font-size: 12px; color: #64748b; margin-bottom: 10px; }
.pcard-count { font-size: 12px; color: #2563eb; font-weight: 600; }
.btn {
  padding: 7px 15px;
  border-radius: 6px;
  border: none;
  cursor: pointer;
  font-size: 13px;
  font-family: "Segoe UI", Arial, sans-serif;
  font-weight: 600;
  -webkit-transition: all 0.15s;
  transition: all 0.15s;
  display: inline-block;
}
.btn-primary { background: #1d4ed8; color: white; }
.btn-primary:hover { background: #1e40af; }
.btn-success { background: #16a34a; color: white; }
.btn-success:hover { background: #15803d; }
.btn-danger { background: #dc2626; color: white; }
.btn-danger:hover { background: #b91c1c; }
.btn-sec { background: #e2e8f0; color: #475569; }
.btn-sec:hover { background: #cbd5e1; }
.btn-lg { padding: 11px 28px; font-size: 14px; }
.tbl { width: 100%; border-collapse: collapse; margin-top: 6px; }
.tbl th { text-align: left; padding: 9px 11px; background: #f8fafc; color: #475569; font-size: 11px; font-weight: 700; text-transform: uppercase; border-bottom: 2px solid #e2e8f0; }
.tbl td { padding: 9px 11px; border-bottom: 1px solid #f1f5f9; font-size: 13px; color: #334155; vertical-align: middle; }
.tbl tr:hover td { background: #f8fafc; }
.fg { margin-bottom: 12px; }
.fg label { display: block; font-size: 11px; font-weight: 700; color: #475569; margin-bottom: 3px; text-transform: uppercase; }
.fi {
  width: 100%;
  padding: 7px 9px;
  border: 1.5px solid #e2e8f0;
  border-radius: 6px;
  font-size: 13px;
  font-family: "Segoe UI", Arial, sans-serif;
  color: #334155;
}
.fi:focus { outline: none; border-color: #3b82f6; }
.sw-list { max-height: 160px; overflow-y: auto; border: 1.5px solid #e2e8f0; border-radius: 6px; }
.sw-item { padding: 7px 10px; display: -ms-flexbox; display: flex; -ms-flex-align: center; align-items: center; gap: 8px; border-bottom: 1px solid #f1f5f9; font-size: 13px; }
.sw-item:last-child { border-bottom: none; }
.sw-item:hover { background: #f8fafc; }
.badge { display: inline-block; padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: 700; }
.b-blue { background: #dbeafe; color: #1d4ed8; }
.b-green { background: #dcfce7; color: #16a34a; }
.b-gray { background: #f1f5f9; color: #64748b; }
.b-purple { background: #ede9fe; color: #7c3aed; }
.b-orange { background: #fff7ed; color: #c2410c; }
.sw-src { font-size: 10px; color: #7c3aed; background: #ede9fe; border-radius: 8px; padding: 1px 6px; margin-left: 4px; }
.log-area {
  background: #0f172a;
  color: #94a3b8;
  padding: 14px;
  border-radius: 8px;
  font-family: Consolas, monospace;
  font-size: 12px;
  height: 290px;
  overflow-y: auto;
  line-height: 1.65;
}
.ll { padding: 1px 0; }
.ls { color: #4ade80; }
.le { color: #f87171; }
.li { color: #60a5fa; }
.lw { color: #fbbf24; }
.prog { height: 8px; background: #e2e8f0; border-radius: 4px; overflow: hidden; margin-top: 10px; }
.prog-fill { height: 100%; background: linear-gradient(90deg,#1d4ed8,#3b82f6); border-radius: 4px; -webkit-transition: width 0.3s; transition: width 0.3s; }
.overlay { position: fixed; top:0; left:0; right:0; bottom:0; background: rgba(0,0,0,0.55); display: -ms-flexbox; display: flex; -ms-flex-align: center; align-items: center; -ms-flex-pack: center; justify-content: center; z-index: 1000; }
.overlay.hidden { display: none; }
.ov-box { background: white; border-radius: 12px; padding: 28px; width: 520px; max-width: 94%; }
.ov-title { font-size: 18px; font-weight: 800; color: #1e3a8a; margin-bottom: 6px; }
.split { display: -ms-flexbox; display: flex; gap: 14px; }
.split-sm { width: 320px; -ms-flex-shrink: 0; flex-shrink: 0; }
.split-main { -ms-flex: 1; flex: 1; }
.flex { display: -ms-flexbox; display: flex; }
.flex-btw { -ms-flex-pack: justify; justify-content: space-between; }
.flex-c { -ms-flex-align: center; align-items: center; }
.flex-wrap { -ms-flex-wrap: wrap; flex-wrap: wrap; }
.flex-grow { -ms-flex-positive: 1; flex-grow: 1; }
.gap8 { gap: 8px; }
.gap16 { gap: 16px; }
.mt8 { margin-top: 8px; }
.mb8 { margin-bottom: 8px; }
.muted { color: #94a3b8; font-size: 12px; }
.empty { text-align: center; padding: 36px; color: #94a3b8; font-size: 14px; }
.mono { font-family: Consolas, monospace; font-size: 11px; }
.mono.link { color: #2563eb; cursor: pointer; text-decoration: underline; }
.mono.link:hover { color: #1d4ed8; background: rgba(37,99,235,0.05); }
.name-link { cursor: pointer; color: #1e3a8a; }
.name-link:hover { color: #2563eb; text-decoration: underline; }
.info-box { background: #eff6ff; border-left: 4px solid #3b82f6; padding: 10px 14px; border-radius: 0 6px 6px 0; font-size: 12px; color: #1e40af; margin-bottom: 12px; }
.tbl-container { border: 1px solid #e2e8f0; border-radius: 6px; position: relative; }
.tbl-scroll { max-height: 520px; overflow-y: auto; }
.tbl-container table { margin-top: 0; width: 100%; border-collapse: collapse; }
.tbl-container thead th { position: -webkit-sticky; position: sticky; top: 0; z-index: 10; border-top: none; }
/* STILI GUIDA */
.guide-card { padding: 30px; line-height: 1.6; color: #334155; }
.guide-h1 { font-size: 24px; color: #1e3a8a; margin-bottom: 20px; border-bottom: 2px solid #e2e8f0; padding-bottom: 10px; }
.guide-h2 { font-size: 18px; color: #2563eb; margin-top: 25px; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
.guide-p { margin-bottom: 15px; font-size: 14px; }
.guide-item { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 15px; margin-bottom: 15px; }
.guide-item b { color: #1e3a8a; }
.guide-tip { background: #f0fdf4; border-left: 4px solid #22c55e; padding: 12px; border-radius: 4px; font-size: 13px; margin: 15px 0; }
.guide-badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 700; margin-left: 5px; }
.btn-wizard { background: #fdf2f8; color: #db2777; border: 1.5px solid #f9a8d4; }
.btn-wizard:hover { background: #fbcfe8; }
.helper-box { background: #f8fafc; border: 1.5px dashed #cbd5e1; border-radius: 8px; padding: 12px; margin-top: 8px; display: none; }
.helper-title { font-size: 11px; font-weight: 800; color: #64748b; text-transform: uppercase; margin-bottom: 8px; display: block; }
.preset-grid { display: -ms-flexbox; display: flex; -ms-flex-wrap: wrap; flex-wrap: wrap; gap: 6px; }
.btn-tiny { padding: 3px 8px; font-size: 10px; border-radius: 4px; }
.bulk-bar { background: #1e3a8a; color: white; padding: 10px 16px; border-radius: 8px; margin-bottom: 12px; display: none; -ms-flex-align: center; align-items: center; -ms-flex-pack: justify; justify-content: space-between; box-shadow: 0 4px 12px rgba(30,58,138,0.2); }
.bulk-count { font-size: 13px; font-weight: 700; color: #fff; }
#splash { position: fixed; top:0; left:0; right:0; bottom:0; background: #1e3a8a; color: white; display: -ms-flexbox; display: flex; -ms-flex-direction: column; flex-direction: column; -ms-flex-align: center; align-items: center; -ms-flex-pack: center; justify-content: center; z-index: 99999; font-family: "Segoe UI", Arial, sans-serif; }
.prof-editor-overlay { position: fixed; top:0; left:0; right:0; bottom:0; background: #f8fafc; z-index: 2000; overflow-y: auto; display: none; padding: 20px; }
.prof-editor-card { background: white; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); width: 1000px; max-width: 98%; margin: 0 auto; min-height: 90vh; display: flex; flex-direction: column; border: 1px solid #e2e8f0; }
.prof-editor-hdr { padding: 20px 24px; border-bottom: 2px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center; background: #fff; border-radius: 12px 12px 0 0; }
.prof-editor-body { padding: 24px; flex-grow: 1; overflow-y: auto; }
.prof-editor-footer { padding: 18px 24px; border-top: 1px solid #e2e8f0; display: flex; justify-content: flex-end; gap: 12px; background: #f8fafc; border-radius: 0 0 12px 12px; }
.list-search { margin-bottom: 10px; position: relative; }
.list-search input { padding-left: 32px; font-size: 12px; }
.list-search:before { content: "\1F50D"; position: absolute; left: 10px; top: 8px; font-size: 12px; opacity: 0.5; }
.sw-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.sw-list-container { display: flex; flex-direction: column; height: 100%; }
.sw-list-box { border: 1.5px solid #e2e8f0; border-radius: 8px; flex-grow: 1; max-height: 450px; overflow-y: auto; background: #fff; }
.sw-item-large { padding: 10px 14px; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; gap: 10px; transition: background 0.1s; }
.sw-item-large:hover { background: #f8fafc; }
.sw-item-large input { cursor: pointer; width: 16px; height: 16px; }
.sw-item-large label { cursor: pointer; flex-grow: 1; font-size: 13px; font-weight: 500; display: block; }
.sw-item-large.selected { background: #eff6ff; border-left: 3px solid #3b82f6; }
.prof-top-form { display: grid; grid-template-columns: 2fr 3fr 1fr; gap: 16px; margin-bottom: 24px; background: #f8fafc; padding: 16px; border-radius: 8px; border: 1px solid #e2e8f0; }
</style>
</head>
<body>
<div id="splash">
  <div style="font-size:38px; font-weight:800; margin-bottom:10px">&#9881; SmartInstaller</div>
  <div style="font-size:16px; opacity:0.8">Inizializzazione in corso... attendere</div>
</div>

<div class="hdr">
  <div>
    <div class="hdr-logo">&#9881; SmartInstaller <span style="font-size:12px;opacity:0.8;font-weight:400;margin-left:8px">v1.34</span></div>
    <div class="hdr-sub">IT Deployment Tool - di <b>Gelsomino Lullo</b> - <span style="color:#fbbf24">Licenza: Freeware per tutti</span></div>
  </div>
  <div style="display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;gap:16px">
    <div class="hdr-path" id="hdrPath"></div>
    <button onclick="reloadCfg()" style="background:rgba(255,255,255,0.15);color:white;border:1px solid rgba(255,255,255,0.35);border-radius:6px;padding:5px 14px;cursor:pointer;font-size:13px;font-family:Segoe UI,Arial,sans-serif;font-weight:600;" title="Ricarica configurazione">&#8635; Ricarica</button>
    <button onclick="if(confirm('Chiudere SmartInstaller?')) window.close();" style="background:rgba(255,255,255,0.15);color:white;border:1px solid rgba(255,255,255,0.35);border-radius:6px;padding:5px 14px;cursor:pointer;font-size:13px;font-family:Segoe UI,Arial,sans-serif;font-weight:600;" title="Chiudi applicazione">&#10005; Chiudi</button>
  </div>
</div>

<div class="nav">
  <button class="nav-btn active" id="nb0" onclick="showView('install')">&#128640; Installazione</button>
  <button class="nav-btn" id="nb1" onclick="showView('software')">&#128230; Libreria Software</button>
  <button class="nav-btn" id="nb2" onclick="showView('profiles')">&#128193; Profili</button>
  <button class="nav-btn" id="nb3" onclick="showView('config')">&#9881; Configurazione</button>
  <button class="nav-btn" id="nb4" onclick="showView('log')">&#128147; Log</button>
  <button class="nav-btn" id="nb5" onclick="showView('guide')">&#128214; Guida</button>
</div>

<div class="main">
<div class="content">

<!-- VIEW: INSTALL -->
<div id="view-install" class="view active">
  <div class="card">
    <div class="card-title" style="display:flex;justify-content:space-between;align-items:center;">
      <span>Seleziona un profilo e avvia l'installazione</span>
      <button class="nav-btn" style="color:#2563eb;padding:4px 8px;font-size:12px;margin:0;border:1px solid #bfdbfe;border-radius:4px" onclick="openGuide('g-install')">&#10068; Aiuto</button>
    </div>
    <div class="muted">Clicca su un profilo. I software dei <b>profili inclusi</b> vengono uniti automaticamente (senza duplicati).</div>
    <div class="pcard-grid" id="pcardGrid">
      <div class="empty">Nessun profilo. Vai su <b>Profili</b> per crearne uno.</div>
    </div>
  </div>
  <div id="installPanel" style="display:none">
    <div class="card">
      <div class="card-title" id="ipTitle">Software da installare</div>
      <div class="tbl-container">
        <table class="tbl">
          <thead><tr><th>#</th><th>Nome</th><th>Percorso</th><th>Argomenti</th><th>Categoria</th><th>Azioni</th></tr></thead>
          <tbody id="ipBody"></tbody>
        </table>
      </div>
      <div style="margin-top:14px;text-align:right">
        <button class="btn btn-success btn-lg" onclick="startInstall()">&#9654; Avvia Installazione</button>
      </div>
    </div>
  </div>
</div>

<!-- VIEW: SOFTWARE -->
<div id="view-software" class="view">
  <div class="card">
    <div class="card-title" style="display:flex;justify-content:space-between;align-items:center;">
      <span id="swFTitle">&#10133; Gestione Software</span>
      <button class="nav-btn" style="color:#2563eb;padding:4px 8px;font-size:12px;margin:0;border:1px solid #bfdbfe;border-radius:4px" onclick="openGuide('g-library')">&#10068; Aiuto</button>
    </div>
    
    <div class="flex flex-wrap gap16">
      <div class="fg flex-grow" style="min-width:250px"><label>Nome *</label><input class="fi" id="swName" placeholder="es. Google Chrome"></div>
      <div class="fg flex-grow" style="min-width:200px"><label>Categoria</label><input class="fi" id="swCat" placeholder="es. Browser, Office, Utility..."></div>
    </div>

    <div class="flex flex-wrap gap16">
      <div class="fg flex-grow" style="min-width:400px">
        <label>Percorso eseguibile o URL *</label>
        <div class="flex gap8">
          <input class="fi" id="swPath" placeholder="\\server\sw.exe, https://link.com/setup.exe oppure un comando PowerShell" style="-ms-flex:1;flex:1">
          <button class="btn btn-sec" onclick="browsePath()" title="Sfoglia file locale/rete">&#128193;</button>
        </div>
      </div>
      <div class="fg flex-grow" style="min-width:300px">
        <label>Argomenti installazione silenziosa</label>
        <div class="flex gap8">
          <input class="fi" id="swArgs" placeholder="es. /S  /quiet  /silent" style="-ms-flex:1;flex:1">
          <button class="btn btn-wizard" onclick="toggleSetupAssistant()" title="Assistente Smart Setup">&#129668;</button>
        </div>
        <div id="setupAssistant" class="helper-box">
           <span class="helper-title">&#129668; Smart Setup Assistant</span>
           <div id="detectMsg" style="font-size:12px;margin-bottom:8px;color:#475569">Seleziona un percorso per attivare l'analisi.</div>
           <div class="preset-grid" id="presetButtons">
              <button class="btn btn-sec btn-tiny" onclick="setArgs('/VERYSILENT /SUPPRESSMSGBOXES /NORESTART')">Inno Setup</button>
              <button class="btn btn-sec btn-tiny" onclick="setArgs('/S')">NSIS</button>
              <button class="btn btn-sec btn-tiny" onclick="setArgs('/quiet /norestart')">MSI Basic</button>
              <button class="btn btn-sec btn-tiny" onclick="setArgs('/s /v\"/qn\"')">InstallShield</button>
              <button class="btn btn-sec btn-tiny" onclick="setArgs('/silent /install')">Chrome/Edge</button>
           </div>
           <div style="margin-top:10px;padding-top:8px;border-top:1px solid #e2e8f0;">
              <button class="btn btn-primary btn-tiny" onclick="testHelp()" style="width:100%">Prova /? (Help Locale)</button>
              <div style="font-size:10px;color:#94a3b8;margin-top:4px">⚠️ Attenzione: se il software non supporta il comando /?, potrebbe avviarsi l'installazione guidata.</div>
           </div>
        </div>
      </div>
    </div>

    <div class="flex flex-wrap gap16 flex-c">
      <div class="fg flex-grow" style="margin-bottom:0"><label>Note</label><input class="fi" id="swNotes" placeholder="Note opzionali..."></div>
      <div class="flex flex-c" style="margin-top:16px;background:#f8fafc;padding:6px 14px;border-radius:8px">
        <label style="font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;margin-right:15px">Azioni permesse:</label>
        <div class="flex flex-c" style="margin-right:25px">
           <input type="checkbox" id="swAllowInstall" style="margin-right:8px;cursor:pointer" checked> 
           <label for="swAllowInstall" style="font-size:12px;cursor:pointer">Installazione</label>
        </div>
        <div class="flex flex-c" style="margin-right:25px">
           <input type="checkbox" id="swAllowCopy" style="margin-right:8px;cursor:pointer"> 
           <label for="swAllowCopy" style="font-size:12px;cursor:pointer">Copia Locale</label>
        </div>
        <div class="flex flex-c">
           <input type="checkbox" id="swPause" style="margin-right:8px;cursor:pointer" checked> 
           <label for="swPause" style="font-size:12px;cursor:pointer" title="Se spuntato, il batch si fermerà alla fine chiedendo di premere un tasto">Pausa finale</label>
        </div>
      </div>
      <div class="flex gap8" style="margin-top:16px">
        <button class="btn btn-primary" onclick="saveSW()" id="swSaveBtn">Salva</button>
        <button class="btn btn-sec" onclick="resetSWForm()">Annulla</button>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="flex flex-btw flex-c mb8" style="gap:16px">
      <div class="card-title" style="margin-bottom:0;min-width:180px">&#128230; Software in libreria</div>
      <div class="flex-grow flex gap8 flex-c">
        <input type="text" class="fi" id="swSearchInput" onkeyup="onSWSearch()" placeholder="Cerca..." style="padding:5px 10px;font-size:13px;max-width:260px">
        <div id="filterIndicator" style="display:none;white-space:nowrap;font-size:11px;background:#eff6ff;padding:4px 10px;border-radius:6px;border:1px solid #bfdbfe;color:#1e40af;font-weight:600;min-width:fit-content">
          <span id="filterVal"></span> 
          <button class="btn btn-tiny btn-danger" onclick="resetSWFilters()" style="padding:2px 8px;margin-left:8px;font-weight:800;white-space:nowrap" title="Rimuovi tutti i filtri">&#10005; Reset</button>
        </div>
      </div>
      <span class="badge b-blue" id="swCount">0 software</span>
    </div>
    
    <div id="bulkBar" class="bulk-bar">
      <div class="flex flex-c gap16">
        <span class="bulk-count" id="bulkCountTxt">0 software selezionati</span>
        <div class="flex flex-c gap8" style="margin-left:8px;border-left:1px solid rgba(255,255,255,0.2);padding-left:16px">
          <label style="font-size:11px;color:rgba(255,255,255,0.8);text-transform:uppercase;font-weight:700">Aggiungi a:</label>
          <select class="fi" id="bulkDestProf" style="width:180px;padding:3px 6px;font-size:12px;color:#000"></select>
          <button class="btn btn-success btn-tiny" onclick="bulkAddToProfile()">Esegui</button>
        </div>
      </div>
      <button class="btn btn-primary btn-tiny" style="background:#3b82f6" onclick="bulkCreateProfile()">&#128194; Crea Nuovo Profilo</button>
    </div>

    <div class="tbl-container tbl-scroll">
      <table class="tbl">
        <thead><tr><th style="width:30px"><input type="checkbox" id="selectAll" onclick="toggleSelectAll()"></th><th>Nome</th><th>Categoria</th><th>Percorso</th><th>Args</th><th>Azioni</th></tr></thead>
        <tbody id="swBody"><tr><td colspan="6" class="empty">Nessun software. Aggiungine uno.</td></tr></tbody>
      </table>
    </div>
  </div>
</div>

