<!-- OVERLAY GUIDA CONTESTUALE -->
<div class="overlay hidden" id="guideOverlay">
  <div class="ov-box" style="width:700px; max-width:90%">
    <div class="ov-title" id="goTit" style="color:#1e3a8a; display:flex; justify-content:space-between; align-items:center;">
      <span>&#128214; Aiuto Contestuale</span>
    </div>
    <div id="goContent" style="margin-top:16px; margin-bottom:20px; color:#334155; line-height:1.6; font-size:14px; max-height:400px; overflow-y:auto; padding-right:8px;">
      <!-- Contenuto dinamico -->
    </div>
    <div style="text-align:right; border-top:1px solid #e2e8f0; padding-top:16px;">
      <button class="btn btn-sec" onclick="document.getElementById('guideOverlay').className='overlay hidden'">&#10005; Chiudi Aiuto</button>
    </div>
  </div>
</div>

<script type="text/javascript">
var cfg = { software: [], profiles: [], settings: { localCopyPath: "C:\\SmartInstaller_Local" } };
var cfgPath = "";

// ---- MANUTENZIONE DRIVE (v1.34) ----
function getUsedDrives() {
  var drives = {};
  for(var i=0; i<cfg.software.length; i++) {
    var p = cfg.software[i].path;
    if (p && p.match(/^[A-Za-z]:\\/)) {
      drives[p.charAt(0).toUpperCase()] = true;
    }
  }
  return Object.keys(drives).sort();
}

function renderDriveTool() {
  var area = document.getElementById("driveToolArea");
  if (!area) return;
  var drives = getUsedDrives();
  if (drives.length === 0) {
    area.innerHTML = "<div style='font-size:12px;color:#64748b'>Nessun percorso locale (es. L:\\) trovato nel database.</div>";
    return;
  }
  var h = "<div style='display:flex;gap:10px;align-items:center;'>";
  h += "<div style='font-size:12px;'>Sostituisci il Drive </div>";
  h += "<select class='fi' id='oldDrive' style='width:60px;padding:2px;height:28px;'>";
  for(var i=0; i<drives.length; i++) h += "<option value='"+drives[i]+"'>"+drives[i]+":</option>";
  h += "</select>";
  h += "<div style='font-size:12px;'> con </div>";
  h += "<input class='fi' id='newDrive' maxlength='1' style='width:45px;padding:2px;height:28px;text-transform:uppercase;text-align:center' placeholder='M'>";
  h += "<button class='btn btn-sec' style='padding:4px 10px;font-size:12px' onclick='bulkReplaceDrive()'>Applica a tutti</button>";
  h += "</div>";
  h += "<div style='margin-top:5px;font-size:10px;color:#ef4444'>* Questa operazione modifica il file config.json in modo permanente.</div>";
  area.innerHTML = h;
}

function bulkReplaceDrive() {
  var oldD = document.getElementById("oldDrive").value;
  var newD = document.getElementById("newDrive").value.trim().toUpperCase();
  if (!newD) { alert("Inserisci la nuova lettera."); return; }
  if (oldD === newD) { alert("Le lettere sono identiche."); return; }
  
  var count = 0;
  var regex = new RegExp("^" + oldD + ":\\\\", "i");
  for(var i=0; i<cfg.software.length; i++) {
    var p = cfg.software[i].path;
    if (p && p.match(regex)) {
      cfg.software[i].path = p.replace(regex, newD + ":\\");
      count++;
    }
  }
  
  if (count > 0) {
    saveCfg();
    addLog("i", "Manutenzione Drive: convertiti " + count + " percorsi da " + oldD + ": a " + newD + ":");
    renderAll();
    renderDriveTool();
    alert("Operazione completata con successo!\n" + count + " percorsi aggiornati nel database.");
  } else {
    alert("Nessun percorso trovato con la lettera selezionata.");
  }
}
var baseDir = "";
var editSwId = null;
var editProfId = null;
var selProfId = null;
var fso = null;
var wsh = null;
var logLines = [];
var swFilterCat = "";
var swSearchText = "";

function runSingleSW(id) {
  var s = byId(cfg.software, id);
  if (!s) return;
  var batchName = "Installa_Singolo_" + s.name.replace(/[^a-zA-Z0-9]/g, "_") + ".bat";
  var baseDir = cfgPath.substring(0, cfgPath.lastIndexOf("\\") + 1);
  var scriptsDir = baseDir + "scripts\\";
  if (!fso.FolderExists(scriptsDir)) fso.CreateFolder(scriptsDir);
  var batchPath = scriptsDir + batchName;
  var b = "@echo off\r\n";
  b += "title SmartInstaller: " + s.name + "\r\n";
  b += "echo ============================================================\r\n";
  b += "echo  SmartInstaller v1.34 - IT Deployment Tool\r\n";
  b += "echo ============================================================\r\n\r\n";
  b += "echo Installazione: " + s.name + "...\r\n";
  var finalPath = s.path;
  var lowPath = finalPath.toLowerCase();
  var isUrl = (lowPath.indexOf("http://") === 0 || lowPath.indexOf("https://") === 0);
  var isPsCmd = (lowPath.indexOf("start-process") >= 0 || lowPath.indexOf("invoke-") >= 0 || lowPath.indexOf("get-") >= 0);
  if (isUrl) {
    var fileName = s.path.substring(s.path.lastIndexOf("/") + 1);
    if (!fileName || fileName.indexOf(".") < 0) fileName = "downloaded_setup.exe";
    var tempPath = cfg.settings.localCopyPath;
    if (tempPath.charAt(tempPath.length-1) !== "\\") tempPath += "\\";
    tempPath += fileName;
    
    b += "echo    Verifica directory di download...\r\n";
    b += "if not exist \"" + cfg.settings.localCopyPath + "\" mkdir \"" + cfg.settings.localCopyPath + "\"\r\n";
    b += "echo    Scaricamento da URL: " + s.path + "\r\n";
    b += "powershell -Command \"Invoke-WebRequest -Uri '" + s.path + "' -OutFile '" + tempPath + "'\"\r\n";
    finalPath = tempPath;
  } else if (s.allowCopy && !s.allowInstall) {
    // Gestione speciale Copia Locale (da Rete)
    var fileNameNet = s.path.substring(s.path.lastIndexOf("\\") + 1);
    var destPath = cfg.settings.localCopyPath;
    if (destPath.charAt(destPath.length-1) !== "\\") destPath += "\\";
    
    b += "echo    Verifica directory di copia locale...\r\n";
    b += "if not exist \"" + cfg.settings.localCopyPath + "\" mkdir \"" + cfg.settings.localCopyPath + "\"\r\n";
    b += "echo    Copia del file in locale...\r\n";
    b += "copy /Y \"" + s.path + "\" \"" + destPath + fileNameNet + "\"\r\n";
    finalPath = destPath + fileNameNet;
  }
  if (isPsCmd) {
    b += "echo    Esecuzione comando PowerShell...\r\n";
    b += "powershell -Command \"" + s.path.replace(/"/g, "\\\"") + "\"\r\n";
  } else {
    b += "start /wait \"\" \"" + finalPath + "\" " + (s.args || "") + "\r\n";
  }
  b += "echo    Completato (exit code: %%errorlevel%%)\r\n";
  if (isUrl) b += "if exist \"" + finalPath + "\" del /q \"" + finalPath + "\"\r\n";
  b += "echo.\r\n";
  b += "echo ============================================================\r\n";
  b += "echo  OPERAZIONE COMPLETATA\r\n";
  b += "echo ============================================================\r\n";
  b += "pause\r\n";
  try {
    var f = fso.CreateTextFile(batchPath, true, false);
    f.Write(b); f.Close();
    wsh.Run("explorer.exe /select,\"" + batchPath + "\"");
    if (confirm("Cartella aperta con il file selezionato.\nVuoi installare '" + s.name + "' adesso come Amministratore?")) {
      wsh.Run("powershell -Command \"Start-Process -FilePath '" + batchPath + "' -Verb RunAs\"", 0, false);
      addLog("s", "Eseguito installazione singola: " + s.name);
    }
  } catch(e) { alert("Errore: " + e.message); }
}

// ---- NAVIGAZIONE ----
function showView(name) {
  var views = ["install","software","profiles","log","guide"];
  for (var i = 0; i < views.length; i++) {
    document.getElementById("view-" + views[i]).className = (views[i] === name) ? "view active" : "view";
    document.getElementById("nb" + i).className = (views[i] === name) ? "nav-btn active" : "nav-btn";
  }
  if (name === "install")  renderProfiles();
  if (name === "software") renderSWTable();
  if (name === "profiles") renderProfTable();
}

function openGuide(sectionId) {
  var target = document.getElementById(sectionId);
  var overlay = document.getElementById('guideOverlay');
  var goTit = document.getElementById('goTit');
  var goContent = document.getElementById('goContent');
  
  if (target && overlay && goTit && goContent) {
    // Estrae il titolo (senza l'icona iniziale se presente, oppure mantenendola)
    goTit.innerHTML = "<span>" + target.innerHTML + "</span>";
    
    // Raccoglie tutti i fratelli successivi finché non incontra un nuovo guide-h2 o fine contenitore
    var htmlContent = "";
    var node = target.nextElementSibling;
    while (node) {
      if (node.tagName.toLowerCase() === 'div' && node.className.indexOf('guide-h2') !== -1) {
        break; // Fine della sezione
      }
      if (node.tagName.toLowerCase() === 'div' || node.tagName.toLowerCase() === 'p') {
          htmlContent += node.outerHTML;
      }
      node = node.nextElementSibling;
    }
    
    goContent.innerHTML = htmlContent;
    overlay.className = "overlay"; // Mostra il popup rimuovendo 'hidden'
  } else {
    // Fallback alla visualizzazione intera se qualcosa va storto
    showView('guide');
  }
}

// Intercettazione globale tasto F1 ed ESC (Aiuto Contestuale)
document.onkeydown = function(e) {
  var key = window.event ? window.event.keyCode : e.keyCode;
  if (key === 112) { // Tasto F1
    if (window.event) { window.event.keyCode = 0; window.event.returnValue = false; } // IE prevention
    if (e.preventDefault) e.preventDefault(); // Standard prevention
    
    // Scopri quale vista è attualmente attiva
    var activeView = document.querySelector('.view.active');
    if (activeView) {
      if (activeView.id === 'view-install') openGuide('g-install');
      else if (activeView.id === 'view-software') openGuide('g-library');
      else if (activeView.id === 'view-profiles') openGuide('g-profiles');
      else if (activeView.id === 'view-config') openGuide('g-config');
      else if (activeView.id === 'view-log') openGuide('g-log');
    }
    return false;
  } else if (key === 27) { // Tasto ESC
    // Chiudi Modal Profili
    var profOverlay = document.getElementById('profEditorOverlay');
    if (profOverlay && profOverlay.style.display === 'block') {
      closeProfileEditor();
    }
    // Chiudi Modal Guida
    var guideOverlay = document.getElementById('guideOverlay');
    if (guideOverlay && guideOverlay.className !== 'overlay hidden') {
      guideOverlay.className = 'overlay hidden';
    }
  }
};

// ---- INIT ----
function init() {
  try {
    window.moveTo(0, 0);
    window.resizeTo(screen.availWidth, screen.availHeight);
    fso = new ActiveXObject("Scripting.FileSystemObject");
    wsh = new ActiveXObject("WScript.Shell");
  } catch(e) {
    alert("Errore: impossibile inizializzare ActiveX.\nAssicurarsi di aprire il file come .hta su Windows.");
    return;
  }

  var dir = "";

  // STRATEGIA 1: legge il percorso dal file creato dal BAT launcher.
  // Il BAT copia l'HTA in %TEMP% e salva in si_cfgpath.txt la cartella di rete originale.
  // Questo permette all'HTA di girare locale (nessuna restrizione zona sicurezza)
  // ma di leggere/scrivere config.json dalla cartella di rete.
  try {
    var ptrFile = wsh.ExpandEnvironmentStrings("%TEMP%") + "\\si_cfgpath.txt";
    if (fso.FileExists(ptrFile)) {
      var f = fso.OpenTextFile(ptrFile, 1, false, -2);
      dir = f.ReadAll(); f.Close();
      dir = dir.replace(/[\r\n\s]+$/, ""); // trim
      if (dir.length > 0 && dir.charAt(dir.length-1) !== "\\") dir += "\\";
      // Verifica che la cartella esista davvero
      if (!fso.FolderExists(dir)) dir = "";
    }
  } catch(ex) { dir = ""; }

  // STRATEGIA 2 (fallback): parsing di location.href — funziona quando si apre l'HTA
  // direttamente in locale senza passare dal BAT.
  if (!dir) {
    var href = location.href;
    var filePath;
    if (href.indexOf("file:////") === 0) {
      filePath = "\\\\" + href.substring(9).replace(/\//g, "\\");
    } else if (href.indexOf("file:///") === 0) {
      filePath = href.substring(8).replace(/\//g, "\\");
    } else {
      filePath = href.replace(/file:\/*/,"").replace(/\//g, "\\");
    }
    dir = filePath.substring(0, filePath.lastIndexOf("\\") + 1);
  }

  baseDir = dir;
  
  // RICERCA AUTOMATICA CONFIG (.json)
  var jsonFiles = [];
  try {
    var folder = fso.GetFolder(baseDir);
    var files = new Enumerator(folder.Files);
    for (; !files.atEnd(); files.moveNext()) {
      var file = files.item();
      if (file.Name.toLowerCase().slice(-5) === ".json") {
        jsonFiles.push({ name: file.Name, date: file.DateLastModified });
      }
    }
  } catch(e) {}

  if (jsonFiles.length === 0) {
    cfgPath = baseDir + "config.json";
  } else if (jsonFiles.length === 1) {
    cfgPath = baseDir + jsonFiles[0].name;
  } else {
    // Ordina per data decrescente (ultimo usato/modificato)
    jsonFiles.sort(function(a,b){ return new Date(b.date) - new Date(a.date); });
    cfgPath = baseDir + jsonFiles[0].name;
  }

  document.getElementById("hdrPath").innerText = cfgPath;
  loadCfg();
  renderAll();
  showView("install");
  addLog("s", "SmartInstaller v1.34 avviato - Licenza Freeware.");
  
  // Rimuove lo splash screen dopo un breve delay per garantire il rendering fluido
  setTimeout(function(){ 
    var s = document.getElementById("splash");
    if(s) s.style.display = "none"; 
  }, 200);
}

// ---- CONFIG ----
function loadCfg() {
  try {
    if (fso.FileExists(cfgPath)) {
      var f = fso.OpenTextFile(cfgPath, 1, false, -1);
      var raw = f.ReadAll(); f.Close();
      cfg = JSON.parse(raw);
    } else {
      cfg = { software: [], profiles: [], settings: { localCopyPath: "C:\\SmartInstaller_Local", libraryDrive: "L" } };
      saveCfg(); // Crea il file vuoto se non esiste
      addLog("s","Nuova configurazione creata: config.json");
    }
  } catch(e) {
    addLog("e","Errore lettura config: " + e.message);
    cfg = { software: [], profiles: [] };
  }
  
  // Normalizzazione struttura per retrocompatibilità
  if (!cfg.software) cfg.software = [];
  if (!cfg.profiles) cfg.profiles = [];
  if (!cfg.settings) cfg.settings = { localCopyPath: "C:\\SmartInstaller_Local" };
  
  // Migrazione: assicura che ogni profilo abbia il campo includes
  for (var i=0; i<cfg.profiles.length; i++) {
    if (!cfg.profiles[i].includes) cfg.profiles[i].includes = [];
  }
}

function reloadCfg() {
  addLog("i", "Ricaricamento dati in corso...");
  loadCfg();
  renderAll();
  alert("Dati ricaricati correttamente.");
}

function saveCfg() {
  try {
    var f = fso.CreateTextFile(cfgPath, true, true);
    f.Write(JSON.stringify(cfg, null, 2));
    f.Close();
    return true;
  } catch(e) {
    alert("Errore salvataggio: " + e.message);
    addLog("e","Errore salvataggio: " + e.message);
    return false;
  }
}

// ---- GESTIONE MULTI-CONFIG ----
function renderCfgList() {
  var b = document.getElementById("cfgListBody");
  if (!baseDir) { b.innerHTML = '<tr><td colspan="4" class="empty">Directory non disponibile.</td></tr>'; return; }
  
  var folder = fso.GetFolder(baseDir);
  var files = new Enumerator(folder.Files);
  var h = "";
  var count = 0;
  
  for (; !files.atEnd(); files.moveNext()) {
    var file = files.item();
    if (file.Name.toLowerCase().slice(-5) === ".json") {
      var fullPath = file.Path;
      var isActive = (fullPath.toLowerCase() === cfgPath.toLowerCase());
      var dateStr = file.DateLastModified;
      
      h += '<tr' + (isActive ? ' style="background:#f0f9ff"' : '') + '>';
      h += '<td><b style="color:' + (isActive ? '#1d4ed8' : '#334155') + '">' + esc(file.Name) + '</b></td>';
      h += '<td class="muted">' + dateStr + '</td>';
      h += '<td>' + (isActive ? '<span class="badge b-green">In uso</span>' : '<span class="badge b-gray">Pronto</span>') + '</td>';
      h += '<td class="flex gap8">';
      if (!isActive) {
        h += '<button class="btn btn-primary btn-tiny" onclick="loadNamedConfig(\'' + esc(file.Name) + '\')">Carica</button>';
        h += '<button class="btn btn-danger btn-tiny" onclick="deleteConfig(\'' + esc(file.Name) + '\')">&#128465;</button>';
      } else {
        h += '<button class="btn btn-sec btn-tiny" disabled title="Configurazione attiva">In uso</button>';
      }
      h += '</td></tr>';
      count++;
    }
  }
  
  if (count === 0) h = '<tr><td colspan="4" class="empty">Nessun file .json trovato.</td></tr>';
  b.innerHTML = h;
}

function loadNamedConfig(filename) {
  if (!confirm('Vuoi caricare la configurazione "' + filename + '"?\nLe modifiche non salvate alla configurazione attuale andranno perse.')) return;
  cfgPath = baseDir + filename;
  document.getElementById("hdrPath").innerText = cfgPath;
  loadCfg();
  renderAll();
  renderCfgList();
  addLog("s", "Caricata configurazione: " + filename);
  alert("Configurazione '" + filename + "' caricata correttamente.");
}

function saveAsConfig() {
  var name = document.getElementById("newCfgName").value.trim().replace(/[^a-zA-Z0-9_\-]/g, "");
  if (!name) { alert("Inserisci un nome valido per il file."); return; }
  var filename = name + ".json";
  var newPath = baseDir + filename;
  
  if (fso.FileExists(newPath)) {
    if (!confirm('Il file "' + filename + '" esiste gia\'. Sovrascriverlo?')) return;
  }
  
  var oldPath = cfgPath;
  cfgPath = newPath;
  if (saveCfg()) {
    addLog("s", "Salvato con nome: " + filename);
    alert("Salvataggio completato: " + filename);
    document.getElementById("hdrPath").innerText = cfgPath;
    document.getElementById("newCfgName").value = "";
    renderCfgList();
  } else {
    cfgPath = oldPath; // Ripristina path originale se fallisce
  }
}

function deleteConfig(filename) {
  var path = baseDir + filename;
  if (path.toLowerCase() === cfgPath.toLowerCase()) {
    alert("Impossibile eliminare la configurazione attiva."); return;
  }
  if (!confirm('Eliminare definitivamente il file "' + filename + '"?')) return;
  
  try {
    fso.DeleteFile(path);
    addLog("w", "Configurazione eliminata: " + filename);
    renderCfgList();
  } catch(e) {
    alert("Errore eliminazione: " + e.message);
  }
}

// ---- NAVIGAZIONE ----
function showView(name) {
  var views = ["install","software","profiles","config","log","guide"];
  for (var i = 0; i < views.length; i++) {
    var v = document.getElementById("view-" + views[i]);
    if (v) v.className = (views[i] === name) ? "view active" : "view";
    var b = document.getElementById("nb" + i);
    if (b) b.className = (views[i] === name) ? "nav-btn active" : "nav-btn";
  }
  if (name === "install")  renderProfiles();
  if (name === "software") renderSWTable();
  if (name === "config") {
    document.getElementById("cfgLocalDir").value = cfg.settings.localCopyPath;
    renderDriveTool();
    renderCfgList();
  }
}


// ---- IMPOSTAZIONI GLOBALI ----
function saveSettings() {
  var p = document.getElementById("cfgLocalDir").value.trim();
  if (!p) { alert("Il percorso non puo' essere vuoto."); return; }
  cfg.settings.localCopyPath = p;
  saveCfg();
  addLog("i", "Impostazioni globali aggiornate. Percorso locale: " + p);
  alert("Impostazioni salvate con successo.");
}

// ---- RESOLVE PROFILE (dipendenze) ----
// Ritorna array di {swId, fromProfile} con deduplicazione
function resolveProfile(profId) {
  var p = byId(cfg.profiles, profId);
  if (!p) return [];
  var seen = {};
  var result = [];
  // Prima: sw dai profili inclusi
  var inclIds = p.includes || [];
  for (var i = 0; i < inclIds.length; i++) {
    var ip = byId(cfg.profiles, inclIds[i]);
    if (!ip) continue;
    var ipSW = ip.software || [];
    for (var j = 0; j < ipSW.length; j++) {
      if (!seen[ipSW[j]]) {
        seen[ipSW[j]] = true;
        result.push({ swId: ipSW[j], fromProfile: ip.name });
      }
    }
  }
  // Poi: sw propri del profilo
  var ownSW = p.software || [];
  for (var k = 0; k < ownSW.length; k++) {
    if (!seen[ownSW[k]]) {
      seen[ownSW[k]] = true;
      result.push({ swId: ownSW[k], fromProfile: null });
    }
  }
  return result;
}

// ---- RENDERING: INSTALL VIEW ----
function renderProfiles() {
  var g = document.getElementById("pcardGrid");
  if (cfg.profiles.length === 0) {
    g.innerHTML = '<div class="empty">Nessun profilo configurato.<br>Vai su <b>Profili</b> per crearne uno.</div>';
    document.getElementById("installPanel").style.display = "none";
    return;
  }
  var h = "";
  for (var i = 0; i < cfg.profiles.length; i++) {
    var p = cfg.profiles[i];
    var resolved = resolveProfile(p.id);
    var incl = (p.includes||[]).length;
    var sel = (selProfId === p.id) ? " sel" : "";
    h += '<div class="pcard' + sel + '" onclick="selectProf(\'' + p.id + '\')">';
    h += '<div class="pcard-icon">' + (p.icon || "&#128187;") + '</div>';
    h += '<div class="pcard-name">' + esc(p.name) + '</div>';
    h += '<div class="pcard-desc">' + esc(p.description || "") + '</div>';
    h += '<div class="pcard-count">&#128230; ' + resolved.length + ' software totali';
    if (incl > 0) h += ' <span class="badge b-purple">+' + incl + ' profili</span>';
    h += '</div></div>';
  }
  g.innerHTML = h;
}

function selectProf(id) {
  selProfId = id;
  renderProfiles();
  var p = byId(cfg.profiles, id);
  if (!p) return;
  var resolved = resolveProfile(id);
  document.getElementById("installPanel").style.display = "block";
  document.getElementById("ipTitle").innerText = "Profilo: " + p.name + "  (" + resolved.length + " software totali)";
  var rows = "";
  if (resolved.length === 0) {
    rows = '<tr><td colspan="5" class="empty">Nessun software nel profilo.</td></tr>';
  } else {
    for (var i = 0; i < resolved.length; i++) {
      var s = byId(cfg.software, resolved[i].swId);
      if (!s) continue;
      var fromTag = resolved[i].fromProfile ? '<span class="sw-src">da: ' + esc(resolved[i].fromProfile) + '</span>' : '';
      rows += '<tr><td style="color:#94a3b8">' + (i+1) + '</td>';
      rows += '<td><b class="name-link" onclick="switchToEditSW(\'' + s.id + '\')" title="Clicca per modificare questo software">' + esc(s.name) + '</b>' + fromTag + '</td>';
      
      var isUrl = (s.path.toLowerCase().indexOf("http://")===0 || s.path.toLowerCase().indexOf("https://")===0);
      var isCmd = (s.path.toLowerCase().indexOf("start-process")>=0 || s.path.toLowerCase().indexOf("invoke-")>=0 || s.path.toLowerCase().indexOf("get-")>=0);
      if(isUrl || isCmd) {
          rows += '<td class="mono" style="max-width:180px;overflow:hidden" title="' + esc(s.path) + '">' + esc(s.path) + '</td>';
      } else {
          rows += '<td class="mono link" style="max-width:180px;overflow:hidden" onclick="openFolder(\'' + esc(s.path).replace(/\\/g,"\\\\") + '\')" title="Clicca per aprire la cartella: ' + esc(s.path) + '">' + esc(s.path) + '</td>';
      }
      
      rows += '<td><span class="badge b-blue">' + esc(s.args || "\u2014") + '</span></td>';
      rows += '<td>' + esc(s.category || "") + '</td>';
      rows += '<td class="flex gap8">';
      if (s.allowInstall !== false) rows += '<button class="btn btn-success btn-tiny" onclick="runSingleSW(\'' + s.id + '\')" title="Installa ora">\u25B6</button>';
      if (s.allowCopy === true) rows += '<button class="btn btn-sec btn-tiny" onclick="copyToLocal(\'' + s.id + '\')" title="Copia in locale">&#128190;</button>';
      rows += '</td></tr>';
    }
  }
  document.getElementById("ipBody").innerHTML = rows;
}

// ---- RENDERING: SOFTWARE TABLE ----
function renderSWTable() {
  var b = document.getElementById("swBody");
  var list = cfg.software;
  
  // Filtraggio dinamico
  if (swFilterCat || swSearchText) {
    var sLow = swSearchText ? swSearchText.toLowerCase() : "";
    var cLow = swFilterCat ? swFilterCat.toLowerCase() : "";
    list = filter(cfg.software, function(s) {
      var matchCat = cLow ? (s.category && s.category.toLowerCase() === cLow) : true;
      var matchText = sLow ? (s.name.toLowerCase().indexOf(sLow) >= 0 || s.path.toLowerCase().indexOf(sLow) >= 0) : true;
      return matchCat && matchText;
    });
    document.getElementById("filterIndicator").style.display = "-ms-flexbox";
    document.getElementById("filterIndicator").style.display = "flex";
    document.getElementById("filterVal").innerText = (swFilterCat ? "Categoria: " + swFilterCat : "") + (swSearchText && swFilterCat ? " + " : "") + (swSearchText ? "Ricerca: " + swSearchText : "");
  } else {
    document.getElementById("filterIndicator").style.display = "none";
  }

  if (list.length === 0) {
    b.innerHTML = '<tr><td colspan="5" class="empty">' + (swFilterCat || swSearchText ? "Nessun software corrisponde ai filtri." : "Nessun software. Aggiungine uno.") + '</td></tr>';
    document.getElementById("swCount").innerText = "0 software";
    return;
  }
  
  // Ordinamento alfabetico
  list.sort(function(a,b){ return a.name.localeCompare(b.name); });
  
  var h = "";
  for (var i=0; i<list.length; i++) {
    var s = list[i];
    var pathShort = s.path.length > 60 ? s.path.substring(0,30) + "..." + s.path.substring(s.path.length-30) : s.path;
    var catBadge = s.category ? '<span class="badge b-green" onclick="setFilterCat(\'' + s.category + '\')" style="cursor:pointer" title="Filtra per questa categoria">' + esc(s.category) + '</span>' : "";
    var canIns = (s.allowInstall !== false);
    var canCop = (s.allowCopy === true);
    var isUrl = (s.path.toLowerCase().indexOf("http://")===0 || s.path.toLowerCase().indexOf("https://")===0);
    var isCmd = (s.path.toLowerCase().indexOf("start-process")>=0 || s.path.toLowerCase().indexOf("invoke-")>=0 || s.path.toLowerCase().indexOf("get-")>=0);
    
    h += '<tr>';
    h += '<td><input type="checkbox" class="sw-sel" value="' + s.id + '" onclick="updateBulkBar()"></td>';
    h += '<td style="font-weight:600;cursor:pointer" onclick="editSW(\'' + s.id + '\')" title="Clicca per modificare">' + esc(s.name) + '</td>';
    h += '<td>' + catBadge + '</td>';
    
    if(isUrl || isCmd) {
      h += '<td class="mono" title="' + esc(s.path) + '">' + esc(pathShort) + '</td>';
    } else {
      h += '<td class="mono link" onclick="openFolder(\'' + esc(s.path).replace(/\\/g,"\\\\") + '\')" title="Clicca per aprire la cartella">' + esc(pathShort) + '</td>';
    }
    h += '<td><span class="badge b-gray">' + esc(s.args || "") + '</span></td>';
    h += '<td class="flex gap8">';
    if (canIns) h += '<button class="btn btn-primary btn-tiny" onclick="runSingleSW(\'' + s.id + '\')" title="Installa ora">\u25B6</button>';
    if (canCop) h += '<button class="btn btn-sec btn-tiny" onclick="copyToLocal(\'' + s.id + '\')" title="Copia/Scarica in locale (C:\\SmartInstaller_Local)">&#128190;</button>';
    h += '<button class="btn btn-sec btn-tiny" onclick="editSW(\'' + s.id + '\')">&#9998;</button>';
    h += '<button class="btn btn-sec btn-tiny" onclick="cloneSW(\'' + s.id + '\')" title="Duplica riga">&#128101;</button>';
    h += '<button class="btn btn-danger btn-tiny" onclick="delSW(\'' + s.id + '\')">&#128465;</button>';
    h += '</td></tr>';
  }
  b.innerHTML = h;
  document.getElementById("swCount").innerText = list.length + " software";
  document.getElementById("selectAll").checked = false;
  updateBulkBar();
}

function toggleSelectAll() {
  var chk = document.getElementById("selectAll").checked;
  var boxes = document.getElementsByClassName("sw-sel");
  for (var i=0; i<boxes.length; i++) boxes[i].checked = chk;
  updateBulkBar();
}

function updateBulkBar() {
  var boxes = document.getElementsByClassName("sw-sel");
  var sel = [];
  for (var i=0; i<boxes.length; i++) { if (boxes[i].checked) sel.push(boxes[i].value); }
  
  var bar = document.getElementById("bulkBar");
  if (sel.length > 0) {
    bar.style.display = "-ms-flexbox";
    bar.style.display = "flex";
    document.getElementById("bulkCountTxt").innerText = sel.length + " software selezionati";
    
    // Popola dropdown profili solo se necessario per non perdere la selezione
    var selProf = document.getElementById("bulkDestProf");
    if (selProf.options.length !== cfg.profiles.length) {
      var currentVal = selProf.value;
      var opt = "";
      for (var j=0; j<cfg.profiles.length; j++) {
        opt += '<option value="' + cfg.profiles[j].id + '">' + esc(cfg.profiles[j].name) + '</option>';
      }
      selProf.innerHTML = opt;
      if (currentVal) selProf.value = currentVal;
    }
  } else {
    bar.style.display = "none";
  }
}

function bulkAddToProfile() {
  var boxes = document.getElementsByClassName("sw-sel");
  var selIds = [];
  for (var i=0; i<boxes.length; i++) { if (boxes[i].checked) selIds.push(boxes[i].value); }
  if (selIds.length === 0) return;
  
  var profId = document.getElementById("bulkDestProf").value;
  var p = byId(cfg.profiles, profId);
  if (!p) return;
  
  if (!p.software) p.software = [];
  var added = 0;
  for (var j=0; j<selIds.length; j++) {
    var sid = selIds[j];
    var exists = false;
    for (var k=0; k<p.software.length; k++) {
      if (String(p.software[k]) === String(sid)) { exists = true; break; }
    }
    if (!exists) {
      p.software.push(sid);
      added++;
    }
  }
  
  saveCfg();
  alert("Aggiunti " + added + " software al profilo '" + p.name + "'.\n" + (selIds.length - added) + " erano già presenti o saltati.");
  resetSWFilters(); // Opzionale: pulisce filtri e selezione
}

function bulkCreateProfile() {
  var boxes = document.getElementsByClassName("sw-sel");
  var selIds = [];
  for (var i=0; i<boxes.length; i++) { if (boxes[i].checked) selIds.push(boxes[i].value); }
  if (selIds.length === 0) return;

  var name = prompt("Inserisci il nome del nuovo profilo:", "Nuovo Profilo");
  if (!name) return;

  var newProf = {
    id: uid(),
    name: name,
    description: "Creato dalla selezione software",
    icon: "&#128194;",
    software: selIds,
    includes: []
  };
  
  cfg.profiles.push(newProf);
  saveCfg();
  alert("Profilo '" + name + "' creato con " + selIds.length + " software.");
  showView("profiles");
}

function copyToLocal(id) {
  var s = byId(cfg.software, id);
  if (!s) return;
  
  var lowPath = s.path.toLowerCase();
  var isUrl = (lowPath.indexOf("http://") === 0 || lowPath.indexOf("https://") === 0);
  var destDir = cfg.settings.localCopyPath;
  if (destDir.charAt(destDir.length-1) !== "\\") destDir += "\\";

  try {
    // 1. Verifica/Crea directory di destinazione
    if (!fso.FolderExists(destDir)) {
      addLog("i", "Creazione directory locale: " + destDir);
      fso.CreateFolder(destDir);
    }

    var finalDest = "";
    if (isUrl) {
      // 2a. Gestione Download da URL
      var fileName = s.path.substring(s.path.lastIndexOf("/") + 1);
      if (!fileName || fileName.indexOf(".") < 0) fileName = "downloaded_file.exe";
      finalDest = destDir + fileName;
      
      addLog("i", "Inizio download diretto: " + s.name);
      var psCmd = "powershell -WindowStyle Hidden -Command \"Invoke-WebRequest -Uri '" + s.path + "' -OutFile '" + finalDest + "'\"";
      wsh.Run(psCmd, 0, true);
      addLog("s", "Download completato: " + fileName);
    } else {
      // 2b. Gestione Copia da Rete/Locale
      var fileNameNet = s.path.substring(s.path.lastIndexOf("\\") + 1);
      finalDest = destDir + fileNameNet;
      
      addLog("i", "Copia in corso: " + s.name);
      fso.CopyFile(s.path, finalDest, true);
      addLog("s", "Copia completata: " + fileNameNet);
    }

    // 3. Mostra la cartella nel file explorer ed evidenzia il file
    if (fso.FileExists(finalDest)) {
      wsh.Run("explorer.exe /select,\"" + finalDest + "\"");
    } else {
      wsh.Run("explorer.exe \"" + destDir + "\"");
    }
  } catch(e) {
    alert("Errore durante la copia/download:\n" + e.message);
    addLog("e", "Errore copia locale (" + s.name + "): " + e.message);
  }
}

function switchToEditSW(id) {
  showView("software");
  editSW(id);
  // Scorri la pagina in basso verso il form di modifica
  window.scrollTo(0, document.body.scrollHeight);
}

function openFolder(path) {
  try {
    if(!path) return;
    if(!fso.FileExists(path) && !fso.FolderExists(path)) {
      // Prova a dedurre la cartella se il file non esiste (es: se \setup.exe e' rotto)
      var dirOnly = path.substring(0, path.lastIndexOf("\\"));
      if(fso.FolderExists(dirOnly)) {
         wsh.Run("explorer.exe \"" + dirOnly + "\"");
         return;
      }
      alert("Il percorso o file specificato non esiste o non ? raggiungibile:\n\n" + path);
      return;
    }
    wsh.Run("explorer.exe /select,\"" + path + "\"");
  } catch(e) {
    alert("Impossibile aprire la cartella.\nErrore: " + e.message);
  }
}

function setFilterCat(cat) {
  swFilterCat = cat;
  renderSWTable();
}

function onSWSearch() {
  swSearchText = document.getElementById("swSearchInput").value.toLowerCase().trim();
  renderSWTable();
}

function resetSWFilters() {
  swFilterCat = "";
  swSearchText = "";
  document.getElementById("swSearchInput").value = "";
  renderSWTable();
}

// ---- RENDERING: PROFILES TABLE ----
function renderProfTable() {
  document.getElementById("profCount").innerText = cfg.profiles.length + " profili";
  var h = "";
  if (cfg.profiles.length === 0) {
    h = '<tr><td colspan="6" class="empty">Nessun profilo. Creane uno.</td></tr>';
  } else {
    for (var i = 0; i < cfg.profiles.length; i++) {
      var p = cfg.profiles[i];
      var resolved = resolveProfile(p.id);
      var inclNames = [];
      var inclIds = p.includes || [];
      for (var j = 0; j < inclIds.length; j++) {
        var ip = byId(cfg.profiles, inclIds[j]);
        if (ip) inclNames.push(ip.name);
      }
      h += '<tr><td><b>' + (p.icon || "&#128187;") + ' ' + esc(p.name) + '</b></td>';
      h += '<td>' + esc(p.description || "") + '</td>';
      h += '<td><span class="badge b-blue">' + (p.software||[]).length + '</span></td>';
      h += '<td>' + (inclNames.length > 0 ? '<span class="badge b-purple">' + esc(inclNames.join(', ')) + '</span>' : '<span class="muted">\u2014</span>') + '</td>';
      h += '<td><span class="badge b-green">' + resolved.length + ' tot</span></td>';
      h += '<td style="white-space:nowrap">';
      h += '<button class="btn btn-sec" onclick="editProf(\'' + p.id + '\')" style="margin-right:4px">&#9998;</button>';
      h += '<button class="btn btn-danger" onclick="delProf(\'' + p.id + '\')">&#128465;</button>';
      h += '</td></tr>';
    }
  }
  document.getElementById("profBody").innerHTML = h;
}

// ---- PROFILES CRUD ----
function openProfileEditor(id) {
  var overlay = document.getElementById("profEditorOverlay");
  overlay.style.display = "block";
  document.body.style.overflow = "hidden"; // Blocca scroll body
  
  if (id) {
    var p = byId(cfg.profiles, id);
    if (!p) return;
    editProfId = id;
    document.getElementById("profFTitle").innerHTML = "&#9998; Modifica Profilo";
    document.getElementById("profSaveBtn").innerText = "Aggiorna Profilo";
    set("profName", p.name);
    set("profDesc", p.description || "");
    set("profIcon", p.icon || "&#128187;");
    renderProfSWList(p.software || []);
    renderProfIncludesList(p.includes || [], id);
  } else {
    resetProfForm();
    renderProfSWList([]);
    renderProfIncludesList([], null);
  }
  updateProfEditorStats();
}

function closeProfileEditor() {
  document.getElementById("profEditorOverlay").style.display = "none";
  document.body.style.overflow = "auto";
  editProfId = null;
}

function renderProfSWList(selIds) {
  var c = document.getElementById("profSWList");
  if (cfg.software.length === 0) {
    c.innerHTML = '<div style="padding:20px;color:#94a3b8;text-align:center">Nessun software in libreria</div>';
    return;
  }
  var h = "";
  // Ordina per nome
  var list = [].concat(cfg.software).sort(function(a,b){ return a.name.localeCompare(b.name); });
  for (var i = 0; i < list.length; i++) {
    var s = list[i];
    var isSel = (indexOf(selIds, s.id) >= 0);
    var chk = isSel ? " checked" : "";
    var cls = isSel ? "sw-item-large selected" : "sw-item-large";
    h += '<div class="' + cls + '" data-name="' + s.name.toLowerCase() + '">';
    h += '<input type="checkbox" id="chk_' + s.id + '" value="' + s.id + '"' + chk + ' onclick="updateProfEditorStats(this)">';
    h += '<label for="chk_' + s.id + '">';
    h += '<span style="font-size:14px; color:#1e3a8a">' + esc(s.name) + '</span>';
    if (s.category) h += ' <span class="badge b-gray" style="margin-left:6px; font-weight:400">' + esc(s.category) + '</span>';
    h += '</label></div>';
  }
  c.innerHTML = h;
}

function renderProfIncludesList(selIds, excludeId) {
  var c = document.getElementById("profIncludesList");
  var others = filter(cfg.profiles, function(p) { return p.id !== excludeId; });
  if (others.length === 0) {
    c.innerHTML = '<div style="padding:20px;color:#94a3b8;text-align:center">Nessun altro profilo disponibile</div>';
    return;
  }
  var h = "";
  for (var i = 0; i < others.length; i++) {
    var p = others[i];
    var isSel = (indexOf(selIds, p.id) >= 0);
    var chk = isSel ? " checked" : "";
    var cls = isSel ? "sw-item-large selected" : "sw-item-large";
    var cnt = (p.software||[]).length;
    h += '<div class="' + cls + '" data-name="' + p.name.toLowerCase() + '">';
    h += '<input type="checkbox" id="pinc_' + p.id + '" value="' + p.id + '"' + chk + ' onclick="updateProfEditorStats(this)">';
    h += '<label for="pinc_' + p.id + '">';
    h += '<span style="font-size:14px; color:#1e3a8a">' + (p.icon || '&#128193;') + ' ' + esc(p.name) + '</span>';
    h += ' <span class="muted" style="margin-left:6px">(' + cnt + ' software)</span>';
    h += '</label></div>';
  }
  c.innerHTML = h;
}

function filterPropriList() {
  var txt = val("searchPropri").toLowerCase();
  var items = document.getElementById("profSWList").querySelectorAll(".sw-item-large");
  for(var i=0; i<items.length; i++) {
    var match = items[i].getAttribute("data-name").indexOf(txt) >= 0;
    items[i].style.display = match ? "flex" : "none";
  }
}

function filterInclList() {
  var txt = val("searchIncl").toLowerCase();
  var items = document.getElementById("profIncludesList").querySelectorAll(".sw-item-large");
  for(var i=0; i<items.length; i++) {
    var match = items[i].getAttribute("data-name").indexOf(txt) >= 0;
    items[i].style.display = match ? "flex" : "none";
  }
}

function updateProfEditorStats(el) {
  if (el) {
    // Evidenzia visivamente la riga se e' un checkbox
    var row = el.parentNode;
    if (el.checked) row.className = row.className.replace("selected","") + " selected";
    else row.className = row.className.replace(" selected","");
  }

  var propri = getCheckedSW();
  var incl = getCheckedIncludes();
  document.getElementById("cntPropri").innerText = propri.length + " selezionati";
  document.getElementById("cntIncl").innerText = incl.length + " selezionati";
  
  // Calcolo totale approssimativo (non deduplicato in real-time)
  var total = propri.length;
  for (var i=0; i<incl.length; i++) {
    var p = byId(cfg.profiles, incl[i]);
    if (p) total += (p.software||[]).length;
  }
  document.getElementById("totalSWBadge").innerText = "Totale stimato: " + total + " software";
}

function saveProfile() {
  var name = val("profName");
  if (!name) { alert("Il nome profilo è obbligatori."); return; }
  var p = {
    name: name,
    description: val("profDesc"),
    icon: val("profIcon") || "&#128187;",
    software: getCheckedSW(),
    includes: getCheckedIncludes()
  };
  if (editProfId) {
    var ep = byId(cfg.profiles, editProfId);
    if (ep) {
       ep.name = p.name; ep.description = p.description; ep.icon = p.icon;
       ep.software = p.software; ep.includes = p.includes;
    }
    addLog("i", "Profilo aggiornato: " + name);
  } else {
    p.id = uid();
    cfg.profiles.push(p);
    addLog("i", "Profilo creato: " + name);
  }
  saveCfg(); renderAll(); closeProfileEditor();
}

function editProf(id) { openProfileEditor(id); }

function delProf(id) {
  var p = byId(cfg.profiles, id);
  if (!p || !confirm('Eliminare il profilo "' + p.name + '"?')) return;
  cfg.profiles = filter(cfg.profiles, function(x){ return x.id !== id; });
  // Rimuovi questo profilo dalle inclusioni di altri
  for (var i=0; i<cfg.profiles.length; i++) {
    cfg.profiles[i].includes = filter(cfg.profiles[i].includes||[], function(x){ return x !== id; });
  }
  addLog("w", "Profilo eliminato: " + p.name);
  saveCfg(); renderAll();
}

function resetProfForm() {
  editProfId = null;
  document.getElementById("profFTitle").innerHTML = "&#10133; Crea Nuovo Profilo";
  document.getElementById("profSaveBtn").innerText = "Salva Profilo";
  set("profName",""); set("profDesc",""); set("profIcon","&#128187;");
  set("searchPropri",""); set("searchIncl","");
}

function getCheckedSW() {
  var boxes = document.getElementById("profSWList").querySelectorAll("input[type=checkbox]");
  var r = [];
  for (var i = 0; i < boxes.length; i++) { if (boxes[i].checked) r.push(boxes[i].value); }
  return r;
}

function getCheckedIncludes() {
  var boxes = document.getElementById("profIncludesList").querySelectorAll("input[type=checkbox]");
  var r = [];
  for (var i = 0; i < boxes.length; i++) { if (boxes[i].checked) r.push(boxes[i].value); }
  return r;
}

// ---- SOFTWARE CRUD ----
function saveSW() {
  var name = document.getElementById("swName").value.trim();
  var path = document.getElementById("swPath").value.trim();
  if (!name || !path) { alert("Nome e percorso sono obbligatori."); return; }
  if (editSwId) {
    var s = byId(cfg.software, editSwId);
    if (s) { 
      s.name=name; s.path=path; s.args=val("swArgs"); s.category=val("swCat"); s.notes=val("swNotes");
      s.allowInstall = document.getElementById("swAllowInstall").checked;
      s.allowCopy = document.getElementById("swAllowCopy").checked;
      s.pause = document.getElementById("swPause").checked;
    }
    addLog("i","Software aggiornato: " + name);
  } else {
    cfg.software.push({ 
      id: uid(), name:name, path:path, args:val("swArgs"), category:val("swCat"), notes:val("swNotes"),
      allowInstall: document.getElementById("swAllowInstall").checked,
      allowCopy: document.getElementById("swAllowCopy").checked,
      pause: document.getElementById("swPause").checked
    });
    addLog("i","Software aggiunto: " + name);
  }
  saveCfg(); renderSWTable(); resetSWForm();
}

function editSW(id) {
  var s = byId(cfg.software, id);
  if (!s) return;
  editSwId = id;
  document.getElementById("swFTitle").innerText = "Modifica Software";
  document.getElementById("swSaveBtn").innerText = "Aggiorna";
  set("swName", s.name); set("swPath", s.path); set("swArgs", s.args||"");
  set("swCat", s.category||""); set("swNotes", s.notes||"");
  document.getElementById("swAllowInstall").checked = (s.allowInstall !== false);
  document.getElementById("swAllowCopy").checked = (s.allowCopy === true);
  document.getElementById("swPause").checked = (s.pause !== false);
}

function cloneSW(id) {
  var s = byId(cfg.software, id);
  if (!s) return;
  editSwId = null; 
  document.getElementById("swFTitle").innerText = "Duplica Software";
  document.getElementById("swSaveBtn").innerText = "Salva";
  set("swName", s.name + " (Copia)"); 
  set("swPath", s.path); set("swArgs", s.args||"");
  set("swCat", s.category||""); set("swNotes", s.notes||"");
  document.getElementById("swAllowInstall").checked = (s.allowInstall !== false);
  document.getElementById("swAllowCopy").checked = (s.allowCopy === true);
  document.getElementById("swPause").checked = (s.pause !== false);
  document.getElementById("swName").focus();
}

function delSW(id) {
  var s = byId(cfg.software, id);
  if (!s || !confirm('Eliminare "' + s.name + '"?\nViene rimosso anche da tutti i profili.')) return;
  cfg.software = filter(cfg.software, function(x){ return x.id !== id; });
  for (var i = 0; i < cfg.profiles.length; i++) {
    cfg.profiles[i].software = filter(cfg.profiles[i].software||[], function(x){ return x !== id; });
  }
  addLog("w","Software eliminato: " + s.name);
  saveCfg(); renderSWTable();
}

function resetSWForm() {
  editSwId = null;
  document.getElementById("swFTitle").innerText = "Aggiungi Software";
  document.getElementById("swSaveBtn").innerText = "Salva";
  set("swName",""); set("swPath",""); set("swArgs",""); set("swCat",""); set("swNotes","");
  document.getElementById("swAllowInstall").checked = true;
  document.getElementById("swAllowCopy").checked = false;
  document.getElementById("swPause").checked = true;
}

function browsePath() {
  try {
    // Determina la directory di partenza dal campo gia' compilato
    var currentPath = document.getElementById("swPath").value.trim();
    var initDir = "\\\\";
    if (currentPath) {
      var lastSlash = currentPath.lastIndexOf("\\");
      if (lastSlash > 0) initDir = currentPath.substring(0, lastSlash);
    }

    // File temporaneo dove PowerShell scrivera' il percorso scelto
    var tempFile = wsh.ExpandEnvironmentStrings("%TEMP%") + "\\schooldeploy_pick.txt";

    // Cancella eventuale file precedente
    if (fso.FileExists(tempFile)) fso.DeleteFile(tempFile);

    // Script PowerShell: apre OpenFileDialog nativo di Windows
    var ps = "[System.Reflection.Assembly]::LoadWithPartialName('System.Windows.Forms') | Out-Null; " +
             "$d = New-Object System.Windows.Forms.OpenFileDialog; " +
             "$d.Title = 'Seleziona il file di installazione'; " +
             "$d.Filter = 'Eseguibili e MSI|*.exe;*.msi;*.msp;*.msu|Tutti i file|*.*'; " +
             "$d.InitialDirectory = '" + initDir.replace(/'/g, "''") + "'; " +
             "$d.CheckFileExists = $false; " +
             "if ($d.ShowDialog() -eq 'OK') { $d.FileName | Out-File -FilePath '" + tempFile + "' -Encoding Default -NoNewline }";

    // Esegue PowerShell in finestra nascosta e attende
    var cmd = "powershell.exe -WindowStyle Hidden -ExecutionPolicy Bypass -Command \"" + ps.replace(/"/g, '\\"') + "\"";
    wsh.Run(cmd, 0, true); // 0=hidden, true=attendi fine

    // Legge il risultato
    if (fso.FileExists(tempFile)) {
      var f = fso.OpenTextFile(tempFile, 1, false, -2);  // -2 = system default (ANSI)
      var result = f.ReadAll();
      f.Close();
      fso.DeleteFile(tempFile);
      result = result.replace(/^\s+|\s+$/g, ""); // trim
      if (result && result.length > 0) {
        document.getElementById("swPath").value = result;
        // Auto-compila il nome se vuoto
        var nameField = document.getElementById("swName");
        if (!nameField.value.trim()) {
          var fname = result.substring(result.lastIndexOf("\\") + 1);
          fname = fname.replace(/\.(exe|msi|msp|msu)$/i, "").replace(/[-_]/g, " ");
          nameField.value = fname;
        }
      }
    }
  } catch(e) {
    alert("Errore apertura dialogo: " + e.message + "\n\nInserisci il percorso manualmente nel campo.");
    document.getElementById("swPath").focus();
  }
}


// ---- INSTALLAZIONE ----
// ---- INSTALLAZIONE (v1.3: Generatore Batch) ----
function startInstall() {
  if (!selProfId) { alert("Seleziona un profilo prima."); return; }
  var p = byId(cfg.profiles, selProfId);
  if (!p) return;
  var resolved = resolveProfile(selProfId);
  if (resolved.length === 0) { alert("Il profilo non contiene software."); return; }

  var batchName = "Installa_" + p.name.replace(/[^a-zA-Z0-9]/g, "_") + ".bat";
  var baseDir = cfgPath.substring(0, cfgPath.lastIndexOf("\\") + 1);
  var scriptsDir = baseDir + "scripts\\";
  if (!fso.FolderExists(scriptsDir)) fso.CreateFolder(scriptsDir);
  var batchPath = scriptsDir + batchName;

  var b = "@echo off\r\n";
  b += "title Installazione: " + p.name + "\r\n";
  b += "echo ============================================================\r\n";
  b += "echo  SmartInstaller v1.34 - Deployment Profilo: " + p.name + "\r\n";
  b += "echo ============================================================\r\n\r\n";

  for (var i = 0; i < resolved.length; i++) {
    var s = byId(cfg.software, resolved[i].swId);
    if (!s || s.allowInstall === false) continue;
    var from = resolved[i].fromProfile ? " (da " + resolved[i].fromProfile + ")" : "";
    b += "echo [" + (i+1) + "/" + resolved.length + "] Installazione: " + s.name + from + "...\r\n";
    
    var finalPath = s.path;
    var lowPath = finalPath.toLowerCase();
    var isUrl = (lowPath.indexOf("http://") === 0 || lowPath.indexOf("https://") === 0);
    var isPsCmd = (lowPath.indexOf("start-process") >= 0 || lowPath.indexOf("invoke-") >= 0 || lowPath.indexOf("get-") >= 0);
    
    if (isUrl) {
      var fileName = s.path.substring(s.path.lastIndexOf("/") + 1);
      if (!fileName || fileName.indexOf(".") < 0) fileName = "downloaded_setup.exe";
      var tempPath = cfg.settings.localCopyPath;
      if (tempPath.charAt(tempPath.length-1) !== "\\") tempPath += "\\";
      tempPath += fileName;
      
      b += "echo    Verifica directory di download...\r\n";
      b += "if not exist \"" + cfg.settings.localCopyPath + "\" mkdir \"" + cfg.settings.localCopyPath + "\"\r\n";
      b += "echo    Scaricamento da URL: " + s.path + "\r\n";
      b += "powershell -Command \"Invoke-WebRequest -Uri '" + s.path + "' -OutFile '" + tempPath + "'\"\r\n";
      finalPath = tempPath;
    } else if (s.allowCopy && !s.allowInstall) {
      // Copia Locale Diretta (da Rete)
      var fileNameNet = s.path.substring(s.path.lastIndexOf("\\") + 1);
      var destPath = cfg.settings.localCopyPath;
      if (destPath.charAt(destPath.length-1) !== "\\") destPath += "\\";
      
      b += "echo    Verifica directory di copia locale...\r\n";
      b += "if not exist \"" + cfg.settings.localCopyPath + "\" mkdir \"" + cfg.settings.localCopyPath + "\"\r\n";
      b += "echo    Copia del file in locale...\r\n";
      b += "copy /Y \"" + s.path + "\" \"" + destPath + fileNameNet + "\"\r\n";
      finalPath = destPath + fileNameNet;
    }

    if (isPsCmd) {
      b += "echo    Esecuzione comando PowerShell...\r\n";
      b += "powershell -Command \"" + s.path.replace(/"/g, "\\\"") + "\"\r\n";
    } else if (s.allowInstall) {
      b += "start /wait \"\" \"" + finalPath + "\" " + (s.args || "") + "\r\n";
    }
    
    b += "echo    Completato (exit code: %%errorlevel%%)\r\n";
    if (isUrl) b += "if exist \"" + finalPath + "\" del /q \"" + finalPath + "\"\r\n";
    b += "echo.\r\n";
    if (s.pause !== false) b += "pause\r\n";
  }

  b += "echo ============================================================\r\n";
  b += "echo  INSTALLAZIONE COMPLETATA\r\n";
  b += "echo ============================================================\r\n";

  try {
    var f = fso.CreateTextFile(batchPath, true, false); // ASCII/ANSI per batch
    f.Write(b);
    f.Close();

    wsh.Run("explorer.exe /select,\"" + batchPath + "\"");

    var msg = "Cartella aperta con lo script selezionato.\n\n";
    msg += "Vuoi eseguire l'installazione del profilo '" + p.name + "' ADESSO come Amministratore?\n";
    msg += "(Richiede una sola conferma UAC)";

    if (confirm(msg)) {
      var psCmd = "Start-Process -FilePath '" + batchPath + "' -Verb RunAs";
      wsh.Run("powershell -Command \"" + psCmd + "\"", 0, false);
      addLog("s", "Eseguito batch: " + batchName + " (richiesta UAC)");
    }
  } catch(e) {
    alert("Errore generazione batch: " + e.message);
    addLog("e", "Errore batch: " + e.message);
  }
}





function setProgress(cur, tot) {
  var pct = tot > 0 ? Math.round((cur/tot)*100) : 0;
  document.getElementById("progFill").style.width = pct + "%";
  document.getElementById("progTxt").innerText = cur + " / " + tot;
}

function closeOverlay() {
  document.getElementById("installOverlay").className = "overlay hidden";
  showView("log");
}

// ---- LOG ----
function addLog(type, msg) {
  var now = new Date();
  var ts = pad(now.getHours()) + ":" + pad(now.getMinutes()) + ":" + pad(now.getSeconds());
  logLines.push("[" + ts + "] " + msg);
  var a = document.getElementById("logArea");
  var d = document.createElement("div");
  d.className = "ll l" + (type==="s"?"s":type==="e"?"e":type==="w"?"w":"i");
  d.innerText = "[" + ts + "] " + msg;
  a.appendChild(d); a.scrollTop = a.scrollHeight;
}

function ovLog(type, msg) {
  var a = document.getElementById("ovLog");
  var d = document.createElement("div");
  d.className = "ll l" + (type==="s"?"s":type==="e"?"e":type==="w"?"w":"i");
  d.innerText = msg;
  a.appendChild(d); a.scrollTop = a.scrollHeight;
}

function clearLog() {
  logLines = [];
  document.getElementById("logArea").innerHTML = '<div class="ll li">Log pulito.</div>';
}

function exportLog() {
  if (logLines.length === 0) { alert("Log vuoto."); return; }
  try {
    var now = new Date();
    var fn = "schooldeploy_log_" + now.getFullYear() + pad(now.getMonth()+1) + pad(now.getDate()) + "_" + pad(now.getHours()) + pad(now.getMinutes()) + ".txt";
    var href = location.href.replace("file:///","").replace(/\//g,"\\");
    if (href.charAt(0)==="\\" && href.charAt(1)!=="\\") href="\\"+href;
    var dir = href.substring(0, href.lastIndexOf("\\")+1);
    var logPath = dir + "logs\\" + fn;
    if (!fso.FolderExists(dir + "logs")) fso.CreateFolder(dir + "logs");
    var f = fso.CreateTextFile(logPath, true, true);
    f.Write("SchoolDeploy - Log esportato il " + now.toLocaleString() + "\r\n");
    f.Write("============================================================\r\n");
    for (var i=0; i<logLines.length; i++) f.Write(logLines[i] + "\r\n");
    f.Close();
    alert("Log esportato in:\n" + logPath);
  } catch(e) { alert("Errore esportazione: " + e.message); }
}
// ---- SMART SETUP ASSISTANT (v1.4) ----
function toggleSetupAssistant() {
  var b = document.getElementById("setupAssistant");
  var isHidden = b.style.display === "" || b.style.display === "none";
  b.style.display = isHidden ? "block" : "none";
  if (isHidden) autoDetectArgs();
}

function autoDetectArgs() {
  var p = document.getElementById("swPath").value.trim().toLowerCase();
  var m = document.getElementById("detectMsg");
  if (!p) { m.innerText = "❌ Inserisci un percorso o un URL per analizzare il software."; return; }
  
  var isUrl = (p.indexOf("http://") === 0 || p.indexOf("https://") === 0);
  var isPsCmd = (p.indexOf("start-process") >= 0 || p.indexOf("invoke-") >= 0 || p.indexOf("get-") >= 0);
  
  if (isUrl) {
    m.innerHTML = "🌐 Rilevato <b>URL Download</b>. Il file verrà scaricato in %TEMP% durante l'installazione.";
  } else if (isPsCmd) {
    m.innerHTML = "⚡ Rilevato <b>Comando PowerShell</b>. Verrà eseguito direttamente tramite powershell.exe.";
  }

  if (p.indexOf(".msi") > 0 || p.indexOf(".msp") > 0) {
    m.innerHTML = (isUrl ? m.innerHTML + "<br>" : "") + "💡 Rilevato pacchetto <b>MSI/MSP</b>.<br>Suggerito: <code class='badge b-green'>/quiet /norestart</code>";
    return;
  }
  
  if (p.indexOf("setup") > 0 || p.indexOf("install") > 0 || p.indexOf("firefox") > 0 || p.indexOf("chrome") > 0) {
     m.innerHTML = (isUrl ? m.innerHTML + "<br>" : "") + "🔍 Possibile installer <b>Standard</b>.<br>Prova i preset qui sotto (es. <code class='badge b-green'>/VERYSILENT</code> o <code class='badge b-green'>/S</code>).";
     return;
  }

  if (!isUrl) m.innerText = "❓ Motore non riconosciuto automaticamente. Usa i preset o prova '/?'.";
}

function setArgs(v) {
  document.getElementById("swArgs").value = v;
}

function testHelp() {
  var p = document.getElementById("swPath").value.trim();
  if (!p) { alert("Inserisci prima il percorso del software."); return; }
  
  try {
    addLog("i", "Tentativo apertura Help per: " + p);
    // Lancio con /? in finestra CMD per catturare eventuali output testuali
    var cmd = "cmd.exe /c \"\"" + p + "\" /? & pause\"";
    wsh.Run(cmd, 1, false);
    alert("Ho provato a lanciare il software con il parametro di aiuto (/?).\n\nSe il programma supporta l'aiuto via console, vedrai una finestra nera.\nSe lo supporta via interfaccia grafica, vedrai un popup del programma stesso.");
  } catch(e) {
    alert("Errore nel lancio dell'aiuto: " + e.message);
  }
}

// ---- UTILITY ----
function renderAll() { renderProfiles(); renderSWTable(); renderProfTable(); }
function uid() { return "id_" + Date.now() + "_" + Math.floor(Math.random()*9999); }
function byId(arr, id) { for(var i=0;i<arr.length;i++) if(arr[i].id===id) return arr[i]; return null; }
function indexOf(arr, v) { for(var i=0;i<arr.length;i++) if(arr[i]===v) return i; return -1; }
function filter(arr, fn) { var r=[]; for(var i=0;i<arr.length;i++) if(fn(arr[i])) r.push(arr[i]); return r; }
function esc(s) { if(!s) return ""; return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;"); }
function pad(n) { return n<10?"0"+n:String(n); }
function val(id) { return document.getElementById(id).value.trim(); }
function set(id,v) { document.getElementById(id).value = v; }

window.onload = init;
</script>
</body>
</html>
